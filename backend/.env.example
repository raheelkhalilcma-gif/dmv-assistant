# ============================================
# DMV ASSISTANT — ENVIRONMENT VARIABLES
# File: backend/.env
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values below
# 3. Never share or upload .env to GitHub!
# ============================================

# ---- APP ----
PORT=3001
NODE_ENV=production
JWT_SECRET=your_super_secret_key_minimum_32_chars_long_change_this

# ---- SUPABASE (Database) ----
# Get from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- SENDGRID (Email) ----
# Get from: app.sendgrid.com → Settings → API Keys → Create Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alerts@dmvassistants.com

# ---- TWILIO (SMS) ----
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# ---- LEMON SQUEEZY (Payments) ----
# Get from: app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1Qxxxxxxxxxxxxxxxxxxxxxxxx
LS_STORE_ID=12345
LS_PRO_VARIANT_ID=67890
LS_FAMILY_VARIANT_ID=11223

# ---- FRONTEND URL ----
# Your Vercel URL or custom domain
FRONTEND_URL=https://dmvassistants.com

# ---- AI ASSISTANT (Optional) ----
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
